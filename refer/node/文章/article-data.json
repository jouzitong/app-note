  "title": "私の毎日の生活",
  "paragraphs": [
    [
      { "text": "私", "kana": "わたし" },
      { "text": "は" },
      { "text": "毎朝", "kana": "まいあさ" },
      { "text": "七時", "kana": "しちじ" },
      { "text": "に" },
      { "text": "起", "kana": "お" },
      { "text": "きます。" }
    ],
    [
      { "text": "朝ご飯", "kana": "あさごはん" },
      { "text": "を" },
      { "text": "食", "kana": "た" },
      { "text": "べて、" },
      { "text": "学校", "kana": "がっこう" },
      { "text": "へ" },
      { "text": "行", "kana": "い" },
      { "text": "きます。" }
    ]
  ],
  "translation": [
    "我每天早上七点起床。",
    "吃完早饭去学校。"
