#!/usr/bin/env bash
set -euo pipefail

APP_ROOT="${APP_ROOT:-/home/app/app-note}"
APP_BIN="${APP_BIN:-$APP_ROOT/app-note}"
PID_FILE="${PID_FILE:-$APP_ROOT/bin/app-note.pid}"
LOG_DIR="${LOG_DIR:-$APP_ROOT/logs}"
CONSOLE_LOG_FILE="${CONSOLE_LOG_FILE:-$LOG_DIR/app-note-console.log}"
APP_LOG_FILE="${APP_LOG_FILE:-$LOG_DIR/app-note.log}"
ENV_NAME="${ENV_NAME:-pro}"
WAIT_SECONDS="${WAIT_SECONDS:-20}"

usage() {
  cat <<'USAGE'
Usage:
  bin/app <command> [options]

Commands:
  start    Start app-note
  stop     Stop app-note
  status   Show app-note status
  log      Tail logs

Global env defaults:
  APP_ROOT=/home/app/app-note
  APP_BIN=$APP_ROOT/app-note
  PID_FILE=$APP_ROOT/bin/app-note.pid
  LOG_DIR=$APP_ROOT/logs
  CONSOLE_LOG_FILE=$LOG_DIR/app-note-console.log
  APP_LOG_FILE=$LOG_DIR/app-note.log
  ENV_NAME=pro
  WAIT_SECONDS=20

Examples:
  bin/app start --env pro
  bin/app stop
  bin/app status
  bin/app log --lines 200
  bin/app log --app --no-follow
USAGE
}

ensure_dirs() {
  mkdir -p "$(dirname "$PID_FILE")" "$LOG_DIR"
}

read_pid() {
  if [ ! -f "$PID_FILE" ]; then
    return 1
  fi
  local pid
  pid="$(cat "$PID_FILE" 2>/dev/null || true)"
  if [ -z "${pid:-}" ]; then
    return 1
  fi
  printf '%s' "$pid"
}

is_running_pid() {
  local pid="$1"
  kill -0 "$pid" >/dev/null 2>&1
}

validate_env_name() {
  local env_name="$1"
  case "$env_name" in
    dev|test|pro) ;;
    *)
      echo "[err] unsupported env: $env_name (allowed: dev|test|pro)" >&2
      exit 2
      ;;
  esac
}

start_app() {
  local env_name="$ENV_NAME"
  declare -a extra_args=()

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --env)
        if [ "$#" -lt 2 ]; then
          echo "[err] --env requires a value" >&2
          exit 2
        fi
        env_name="$2"
        shift 2
        ;;
      --)
        shift
        extra_args=("$@")
        break
        ;;
      -h|--help)
        cat <<'USAGE'
Usage: bin/app start [--env dev|test|pro] [-- <extra-args>]
USAGE
        exit 0
        ;;
      *)
        echo "[err] unknown arg for start: $1" >&2
        exit 2
        ;;
    esac
  done

  validate_env_name "$env_name"

  if [ ! -x "$APP_BIN" ]; then
    echo "[err] binary not executable: $APP_BIN" >&2
    exit 1
  fi

  ensure_dirs

  if pid="$(read_pid)"; then
    if is_running_pid "$pid"; then
      echo "[err] app-note already running (pid=$pid)"
      exit 1
    fi
    echo "[warn] removing stale pid file: $PID_FILE"
    rm -f "$PID_FILE"
  fi

  cmd=(
    "$APP_BIN"
    "--spring.profiles.active=$env_name"
    "--spring.config.additional-location=file:$APP_ROOT/config/"
    "--logging.file.name=$APP_LOG_FILE"
  )
  if ((${#extra_args[@]} > 0)); then
    cmd+=("${extra_args[@]}")
  fi

  echo "[run] ${cmd[*]}"
  echo "[run] console log: $CONSOLE_LOG_FILE"
  echo "[run] app log: $APP_LOG_FILE"
  nohup "${cmd[@]}" >> "$CONSOLE_LOG_FILE" 2>&1 &
  echo $! > "$PID_FILE"
  echo "[ok] started pid=$(cat "$PID_FILE")"
}

stop_app() {
  local wait_seconds="$WAIT_SECONDS"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --wait)
        if [ "$#" -lt 2 ]; then
          echo "[err] --wait requires seconds" >&2
          exit 2
        fi
        wait_seconds="$2"
        shift 2
        ;;
      -h|--help)
        cat <<'USAGE'
Usage: bin/app stop [--wait seconds]
USAGE
        exit 0
        ;;
      *)
        echo "[err] unknown arg for stop: $1" >&2
        exit 2
        ;;
    esac
  done

  if ! pid="$(read_pid)"; then
    echo "[ok] pid file not found, app likely stopped: $PID_FILE"
    return 0
  fi

  if ! is_running_pid "$pid"; then
    echo "[ok] process not running, cleaning stale pid file: $PID_FILE"
    rm -f "$PID_FILE"
    return 0
  fi

  echo "[stop] stopping pid=$pid"
  kill "$pid"

  for _ in $(seq 1 "$wait_seconds"); do
    if ! is_running_pid "$pid"; then
      rm -f "$PID_FILE"
      echo "[ok] stopped"
      return 0
    fi
    sleep 1
  done

  echo "[warn] graceful stop timeout, force killing pid=$pid"
  kill -9 "$pid" >/dev/null 2>&1 || true
  rm -f "$PID_FILE"
  echo "[ok] stopped (force)"
}

status_app() {
  if ! pid="$(read_pid)"; then
    echo "stopped (pid file missing)"
    return 1
  fi

  if is_running_pid "$pid"; then
    echo "running (pid=$pid)"
    echo "console_log=$CONSOLE_LOG_FILE"
    echo "app_log=$APP_LOG_FILE"
    return 0
  fi

  echo "stopped (stale pid=$pid)"
  return 1
}

log_app() {
  local lines="${LINES:-200}"
  local follow=1
  local log_target="console"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --lines)
        if [ "$#" -lt 2 ]; then
          echo "[err] --lines requires a number" >&2
          exit 2
        fi
        lines="$2"
        shift 2
        ;;
      --no-follow)
        follow=0
        shift
        ;;
      --app)
        log_target="app"
        shift
        ;;
      --console)
        log_target="console"
        shift
        ;;
      -h|--help)
        cat <<'USAGE'
Usage: bin/app log [--lines N] [--no-follow] [--app|--console]
USAGE
        exit 0
        ;;
      *)
        echo "[err] unknown arg for log: $1" >&2
        exit 2
        ;;
    esac
  done

  local log_file="$CONSOLE_LOG_FILE"
  if [ "$log_target" = "app" ]; then
    log_file="$APP_LOG_FILE"
  fi

  if [ ! -f "$log_file" ]; then
    echo "[err] log file not found: $log_file" >&2
    exit 1
  fi

  if [ "$follow" -eq 1 ]; then
    exec tail -n "$lines" -f "$log_file"
  else
    exec tail -n "$lines" "$log_file"
  fi
}

if [ "$#" -lt 1 ]; then
  usage
  exit 2
fi

command="$1"
shift

case "$command" in
  start) start_app "$@" ;;
  stop) stop_app "$@" ;;
  status) status_app "$@" ;;
  log) log_app "$@" ;;
  -h|--help|help) usage ;;
  *)
    echo "[err] unknown command: $command" >&2
    usage
    exit 2
    ;;
esac
