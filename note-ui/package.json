{
  "name": "note-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "serve": "vue-cli-service serve",
    "build": "vue-cli-service build",
    "lint": "vue-cli-service lint",
    "lint:ci": "npm run lint",
    "test:unit": "jest --runInBand",
    "test:unit:watch": "jest --watch",
    "gen:domain": "node scripts/gen-domain.js"
  },
  "dependencies": {
    "core-js": "^3.8.3",
    "vue": "^2.6.14",
    "vue-router": "^3.5.1",
    "vuex": "^3.6.2"
  },
  "devDependencies": {
    "@babel/core": "^7.12.16",
    "@babel/eslint-parser": "^7.12.16",
    "@vue/cli-plugin-babel": "~5.0.0",
    "@vue/cli-plugin-eslint": "~5.0.0",
    "@vue/cli-plugin-router": "~5.0.0",
    "@vue/cli-plugin-vuex": "~5.0.0",
    "@vue/cli-service": "~5.0.0",
    "babel-jest": "^29.7.0",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-vue": "^8.0.3",
    "jest": "^29.7.0",
    "prettier": "^2.4.1",
    "sass": "^1.99.0",
    "sass-loader": "^12.6.0",
    "vue-template-compiler": "^2.6.14"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "plugins": [
      "import"
    ],
    "extends": [
      "plugin:vue/essential",
      "eslint:recommended",
      "plugin:prettier/recommended"
    ],
    "parserOptions": {
      "parser": "@babel/eslint-parser"
    },
    "rules": {
      "import/no-cycle": [
        "error",
        {
          "maxDepth": 1
        }
      ]
    },
    "overrides": [
      {
        "files": [
          "src/**/*.{js,vue}"
        ],
        "excludedFiles": [
          "src/router/**"
        ],
        "rules": {
          "no-restricted-imports": [
            "error",
            {
              "patterns": [
                {
                  "group": [
                    "@/views/test/**"
                  ],
                  "message": "业务代码禁止依赖测试页面；请通过 router/test.js 挂载测试路由。"
                },
                {
                  "group": [
                    "@/views/**/pages/**"
                  ],
                  "message": "禁止跨模块直接依赖页面文件，请通过 services/components 复用。"
                }
              ]
            }
          ]
        }
      },
      {
        "files": [
          "src/model/api/**/*.{js,ts,vue}"
        ],
        "rules": {
          "no-restricted-imports": [
            "error",
            {
              "patterns": [
                {
                  "group": [
                    "@/views/**"
                  ],
                  "message": "model/api 不得依赖 views 层。"
                }
              ]
            }
          ]
        }
      },
      {
        "files": [
          "src/**/__tests__/**/*.js"
        ],
        "env": {
          "jest": true
        }
      }
    ]
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}
